    )

    footer = ft.Container(
        padding=pad(28, 26),
        bgcolor=SURFACE,
        border=ft.border.only(top=ft.border.BorderSide(1, BORDER)),
        content=ft.Column([
            ft.Text("Nambuli Ndaitavela Ndapwoshisho | SiteSpy Portfolio", color=TEXT, size=18, weight=ft.FontWeight.W_900),
            ft.Text("Prepared as a complete Flet portfolio with a matching static GitHub Pages version in /site.", color=MUTED),
        ], spacing=8),
    )

    page.add(hero, overview, contributions, evidence, validation, footer)


if __name__ == "__main__":
    ft.run(main, assets_dir="assets")
